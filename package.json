{
  "name": "justserpapi-openclaw-websearch",
  "version": "0.1.0",
  "description": "OpenClaw web_search provider plugin for JustSerpAPI",
  "type": "module",
  "private": true,
  "main": "./index.ts",
  "license": "MIT",
  "homepage": "https://justserpapi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justserpapi/justserpapi-openclaw-websearch.git"
  },
  "bugs": {
    "url": "https://github.com/justserpapi/justserpapi-openclaw-websearch/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "search-provider",
    "web-search",
    "serp",
    "serp-api",
    "google-search",
    "justserpapi"
  ],
  "files": [
    "README.md",
    "index.ts",
    "openclaw.plugin.json",
    "src/config.ts",
    "src/justserpapi-client.ts",
    "src/justserpapi-search-provider.ts"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.21"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "providers": [
      "justserpapi"
    ]
  }
